############
# SUPABASE SELF-HOSTED — ENVIRONMENT CONFIGURATION
#
# Copy this file to .env and fill in your values before running:
#   docker compose up -d
#
# NEVER use the default placeholder values in production.
# Run: sh ./utils/generate-keys.sh   to generate all secrets at once.
#
# Documentation:
#   https://supabase.com/docs/guides/self-hosting/docker
############


############
# SECRETS — Change ALL of these before starting for the first time
############

# Master Postgres password. Used by every service that connects to the DB.
# Use a strong random string (24+ characters).
POSTGRES_PASSWORD=your-super-secret-and-long-postgres-password

# ── JWT / API Keys ────────────────────────────────────────────────────────────
# Symmetric HS256 secret — the root key that ANON_KEY and SERVICE_ROLE_KEY
# are signed with. Must be identical across all services.
# Minimum 32 characters. Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters-long

# ANON_KEY — Public "safe to expose in browser" API key.
# This is a JWT with payload: { "role": "anon", "iss": "supabase" }
# signed with JWT_SECRET above.
# Generate at: https://supabase.com/docs/guides/self-hosting/docker#generate-api-keys
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyAgCiAgICAicm9sZSI6ICJhbm9uIiwKICAgICJpc3MiOiAic3VwYWJhc2UtZGVtbyIsCiAgICAiaWF0IjogMTY0MTc2OTIwMCwKICAgICJleHAiOiAxNzk5NTM1NjAwCn0.dc_X5iR_VP_qT0zsiyj_I_OZ2T9FtRU2BBNWN8Bu4GE

# SERVICE_ROLE_KEY — Admin API key. Bypasses ALL Row Level Security.
# NEVER expose this in client-side code or browsers.
# This is a JWT with payload: { "role": "service_role", "iss": "supabase" }
# signed with JWT_SECRET above.
SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyAgCiAgICAicm9sZSI6ICJzZXJ2aWNlX3JvbGUiLAogICAgImlzcyI6ICJzdXBhYmFzZS1kZW1vIiwKICAgICJpYXQiOiAxNjQxNzY5MjAwLAogICAgImV4cCI6IDE3OTk1MzU2MDAKfQ.DaYlNEoUrrEn2Ig7tqibS-PHK5vgusbcbo7X36XVt4Q

# ── New asymmetric key format (ES256) — optional, leave empty if not using ────
# Run: sh ./utils/add-new-auth-keys.sh  to generate these
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
JWT_KEYS=
JWT_JWKS=
ANON_KEY_ASYMMETRIC=
SERVICE_ROLE_KEY_ASYMMETRIC=

# ── Dashboard login credentials ───────────────────────────────────────────────
# Basic auth for the Studio UI (shown at SUPABASE_PUBLIC_URL)
DASHBOARD_USERNAME=supabase
DASHBOARD_PASSWORD=this_password_is_insecure_and_should_be_updated

# ── Service secrets ───────────────────────────────────────────────────────────
# Used by Realtime (Phoenix) and Supavisor (Elixir) — Elixir app secret key.
# Generate with: openssl rand -base64 64
SECRET_KEY_BASE=UpNVntn3cDxHJpq99YMc1T1AQgQpc8kfYTuRgBiYa15BLrx8etQoXz3gZv1/u2oq

# Encryption key used by Supavisor (Vault). Must be exactly 32 characters.
VAULT_ENC_KEY=your-32-character-encryption-key

# Encryption key used by postgres-meta (Studio DB introspection). Min 32 chars.
PG_META_CRYPTO_KEY=your-encryption-key-32-chars-min

# ── Analytics access tokens ───────────────────────────────────────────────────
# Public token: used by Vector to ship logs → Logflare, and by Studio to read logs
LOGFLARE_PUBLIC_ACCESS_TOKEN=your-super-secret-and-long-logflare-key-public
# Private token: used by Studio for log management operations
LOGFLARE_PRIVATE_ACCESS_TOKEN=your-super-secret-and-long-logflare-key-private

# ── Storage S3 protocol credentials ──────────────────────────────────────────
# Used to access Supabase Storage via the S3-compatible endpoint
S3_PROTOCOL_ACCESS_KEY_ID=625729a08b95bf1b7ff351a663f3a23c
S3_PROTOCOL_ACCESS_KEY_SECRET=850181e4652dd023b7a98c58ae0d2d34bd487ee0cc3254aed6eda37307425907


############
# URLS — Set these to match your actual domain before exposing to the internet
############

# Public URL of the API gateway (Kong). Your frontend connects here.
# In production: https://supabase.yourdomain.com
SUPABASE_PUBLIC_URL=http://localhost:8000

# External URL of the Auth API — used to construct:
#   - OAuth redirect callbacks
#   - SAML endpoints
#   - Email verification links
# Must be reachable from the user's browser/device.
# In production: https://supabase.yourdomain.com
API_EXTERNAL_URL=http://localhost:8000

# Your frontend app URL — used as default redirect after email confirmation.
# Example: http://localhost:3000 for dev, https://yourapp.com for production
SITE_URL=http://localhost:3000

# Comma-separated list of additional allowed OAuth redirect URLs
# Example: https://yourapp.com,myapp://callback
ADDITIONAL_REDIRECT_URLS=


############
# DATABASE — Postgres configuration
############

# Hostname of the Postgres container (matches the service name in docker-compose.yml)
POSTGRES_HOST=db
# Database name
POSTGRES_DB=postgres
# Port Postgres listens on inside Docker network.
# Note: Supavisor exposes this port on the host (5432), not Postgres directly.
POSTGRES_PORT=5432


############
# SUPAVISOR — Connection pooler configuration
############

# Port for transaction mode connections (use this in your app in production)
# Transaction mode: connection is returned to pool after each transaction
# Supports 10,000+ concurrent client connections
POOLER_PROXY_PORT_TRANSACTION=6543

# Number of real Postgres connections Supavisor maintains per pool
# Start with 20. Increase if you see pool exhaustion errors.
POOLER_DEFAULT_POOL_SIZE=20

# Max concurrent client connections Supavisor will accept
POOLER_MAX_CLIENT_CONN=100

# Unique identifier for this Supabase instance — used in connection strings.
# Example transaction mode connection:
#   postgres://postgres.<POOLER_TENANT_ID>:<password>@<host>:6543/postgres
POOLER_TENANT_ID=your-tenant-id

# Internal pool size used by Supavisor itself (not for your app connections)
POOLER_DB_POOL_SIZE=5


############
# STUDIO — Dashboard display settings
############

STUDIO_DEFAULT_ORGANIZATION=Default Organization
STUDIO_DEFAULT_PROJECT=Default Project

# Add your OpenAI API key to enable the AI SQL Assistant in Studio
# Leave empty to disable
OPENAI_API_KEY=


############
# AUTH — GoTrue configuration
############

# How long access tokens remain valid (seconds). Default: 1 hour.
JWT_EXPIRY=3600

# Set to true to prevent new signups (users must be invited manually)
DISABLE_SIGNUP=false

# ── Mailer URL paths ──────────────────────────────────────────────────────────
# Paths appended to API_EXTERNAL_URL in email links
MAILER_URLPATHS_CONFIRMATION="/auth/v1/verify"
MAILER_URLPATHS_INVITE="/auth/v1/verify"
MAILER_URLPATHS_RECOVERY="/auth/v1/verify"
MAILER_URLPATHS_EMAIL_CHANGE="/auth/v1/verify"

# ── Email auth ────────────────────────────────────────────────────────────────
ENABLE_EMAIL_SIGNUP=true
# Set to true in development to skip email confirmation step
ENABLE_EMAIL_AUTOCONFIRM=false

# SMTP config — configure your email provider here.
# For local development: run a mail catcher like Mailpit (https://mailpit.axllent.org)
#   docker run -d -p 8025:8025 -p 1025:1025 axllent/mailpit
#   Then set SMTP_HOST=host.docker.internal and SMTP_PORT=1025
SMTP_ADMIN_EMAIL=admin@example.com
SMTP_HOST=supabase-mail
SMTP_PORT=2500
SMTP_USER=fake_mail_user
SMTP_PASS=fake_mail_password
SMTP_SENDER_NAME=fake_sender

# ── Anonymous auth ────────────────────────────────────────────────────────────
# Allow users to sign in without an account (anonymous sessions)
ENABLE_ANONYMOUS_USERS=false

# ── Phone auth ────────────────────────────────────────────────────────────────
ENABLE_PHONE_SIGNUP=true
# Set to true in development to skip SMS verification
ENABLE_PHONE_AUTOCONFIRM=true

# ── OAuth providers ───────────────────────────────────────────────────────────
# Uncomment the providers you want to enable.
# You MUST also uncomment the matching GOTRUE_EXTERNAL_* lines in docker-compose.yml.
# Docs: https://supabase.com/docs/guides/self-hosting/self-hosted-oauth

# GOOGLE_ENABLED=false
# GOOGLE_CLIENT_ID=
# GOOGLE_SECRET=

# GITHUB_ENABLED=false
# GITHUB_CLIENT_ID=
# GITHUB_SECRET=

# AZURE_ENABLED=false
# AZURE_CLIENT_ID=
# AZURE_SECRET=

# ── SMS / Phone provider ──────────────────────────────────────────────────────
# Uncomment and configure to enable phone auth or phone MFA.
# You MUST also uncomment the matching GOTRUE_SMS_* lines in docker-compose.yml.

# SMS_PROVIDER=twilio
# SMS_OTP_EXP=60
# SMS_OTP_LENGTH=6
# SMS_MAX_FREQUENCY=60s
# SMS_TEMPLATE=Your code is {{ .Code }}

# SMS_TWILIO_ACCOUNT_SID=
# SMS_TWILIO_AUTH_TOKEN=
# SMS_TWILIO_MESSAGE_SERVICE_SID=

# For development: map phone numbers to fixed OTP codes (format: phone:code,phone:code)
# SMS_TEST_OTP=

# ── Multi-factor authentication (MFA) ─────────────────────────────────────────
# Uncomment to change from defaults.
# You MUST also uncomment the matching GOTRUE_MFA_* lines in docker-compose.yml.

# MFA_TOTP_ENROLL_ENABLED=true   # Authenticator app (TOTP) — enabled by default
# MFA_TOTP_VERIFY_ENABLED=true
# MFA_PHONE_ENROLL_ENABLED=false # Phone MFA — disabled by default
# MFA_PHONE_VERIFY_ENABLED=false
# MFA_MAX_ENROLLED_FACTORS=10

# ── SAML SSO ──────────────────────────────────────────────────────────────────
# You MUST also uncomment the matching GOTRUE_SAML_* lines in docker-compose.yml.
# Docs: https://supabase.com/docs/guides/self-hosting/self-hosted-saml-sso

# SAML_ENABLED=true
# SAML_PRIVATE_KEY=<your-base64-encoded-private-key>
# SAML_ALLOW_ENCRYPTED_ASSERTIONS=false
# SAML_RELAY_STATE_VALIDITY_PERIOD=2m0s
# SAML_EXTERNAL_URL=https://supabase.yourdomain.com:8000
# SAML_RATE_LIMIT_ASSERTION=15


############
# STORAGE
############

# Bucket/directory name.
# When STORAGE_BACKEND=file (default): this is the folder name inside volumes/storage/
# When STORAGE_BACKEND=s3: this is the S3 bucket name
GLOBAL_S3_BUCKET=stub

# AWS region (used when STORAGE_BACKEND=s3)
REGION=stub

# MinIO root credentials (used when adding MinIO via docker-compose.s3.yml)
MINIO_ROOT_USER=supa-storage
MINIO_ROOT_PASSWORD=secret1234

# Storage tenant identifier
STORAGE_TENANT_ID=stub


############
# EDGE FUNCTIONS
############

# Set to "true" in production to require a valid JWT for every function invocation
# Set to "false" in development for easier testing
FUNCTIONS_VERIFY_JWT=false


############
# POSTGREST (REST API)
############

# Comma-separated list of Postgres schemas to expose via the REST API
# graphql_public exposes the GraphQL endpoint at /rest/v1/rpc/graphql
PGRST_DB_SCHEMAS=public,storage,graphql_public

# Maximum rows returned by a single REST request (protects against large queries)
PGRST_DB_MAX_ROWS=1000

# Extra schemas prepended to every request's search_path
PGRST_DB_EXTRA_SEARCH_PATH=public


############
# ANALYTICS (Logflare + Vector)
############

# Location of Docker socket — needed by Vector to read container logs
# Default for Docker Desktop and most Linux installs:
DOCKER_SOCKET_LOCATION=/var/run/docker.sock
# For rootless Docker, change to:
# DOCKER_SOCKET_LOCATION=/run/user/1000/docker.sock
# For Podman:
# DOCKER_SOCKET_LOCATION=/run/podman/podman.sock

# Google Cloud project (only needed if using BigQuery analytics backend)
GOOGLE_PROJECT_ID=GOOGLE_PROJECT_ID
GOOGLE_PROJECT_NUMBER=GOOGLE_PROJECT_NUMBER


############
# KONG (API Gateway)
############

# Port Kong listens on (HTTP) — your app connects here
KONG_HTTP_PORT=8000
# Port Kong listens on (HTTPS) — configure TLS separately
KONG_HTTPS_PORT=8443


############
# IMGPROXY
############

# Automatically serve WebP images to browsers that support it
IMGPROXY_AUTO_WEBP=true


############
# TLS (HTTPS) — Optional reverse proxy
# Docs: https://supabase.com/docs/guides/self-hosting/self-hosted-proxy-https
#
# To enable HTTPS with Let's Encrypt (Caddy):
#   docker compose -f docker-compose.yml -f docker-compose.caddy.yml up -d
#
# To enable HTTPS with Let's Encrypt (Nginx):
#   docker compose -f docker-compose.yml -f docker-compose.nginx.yml up -d
############

# Your domain name (must point to this server)
PROXY_DOMAIN=your-domain.example.com

# Email for Let's Encrypt certificate renewal notifications (nginx only)
CERTBOT_EMAIL=admin@example.com
